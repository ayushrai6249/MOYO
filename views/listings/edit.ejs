<% layout('layouts/boilerplate') -%>

    <div class="row mt-3">
        <div class="col-8 offset-2">
            <h3>Edit your Listing</h3>
            <form method="post" action="/listings/<%=listing._id%>?_method=PATCH" novalidate class="needs-validation"
                enctype="multipart/form-data">
                <div class="mb-3">
                    <label for="title" class="form-label">Title</label>
                    <input name="listing[title]" placeholder="Enter title" type="text" value="<%=listing.title%>"
                        class="form-control" required>
                    <div class="valid-feedback">Title is filled!</div>
                    <div class="invalid-feedback">This is required</div>
                </div>
                <div class="mb-3">
                    <label for="Description" class="form-label">Description</label>
                    <textarea name="listing[description]" placeholder="Enter description" class="form-control"
                        required><%= listing.description %></textarea>
                    <div class="invalid-feedback">This is required</div>
                </div>
                <div class="mb-3">
                    <i>Original Listing Image</i><br>
                    <div
                        style="position: relative; width: 100%; max-width: 300px; aspect-ratio: 4 / 3; overflow: hidden; border-radius: 8px;">
                        <img src="<%= originalImageUrl %>" alt="listing_image"
                            style="position: absolute; width: 100%; height: 100%; object-fit: cover;">
                    </div>
                </div>
                <div class="mb-3">
                    <label for="image" class="form-label">Upload New Image</label>
                    <input name="listing[image]" type="file" value="<%=listing.image%>" class="form-control">
                    <div class="valid-feedback">This is ok!</div>
                </div>
                <div class="row">
                    <div class="mb-3 col-md-4">
                        <label for="price" class="form-label">Price</label>
                        <input name="listing[price]" placeholder="Enter amount" type="number" value="<%=listing.price%>"
                            class="form-control" required>
                        <div class="invalid-feedback">This is required</div>
                    </div>
                    <div class="mb-3 col-md-8">
                        <label for="country" class="form-label">Country</label>
                        <input name="listing[country]" placeholder="Enter country" type="text"
                            value="<%=listing.country%>" class="form-control" required>
                        <div class="invalid-feedback">This is required</div>
                    </div>
                </div>
                <div class="mb-3">
                    <label for="location" class="form-label">Location</label>
                    <input name="listing[location]" placeholder="Enter location" type="text"
                        value="<%=listing.location%>" class="form-control" required>
                    <div class="invalid-feedback">This is required</div>
                </div>
                <button class="btn btn-dark mt-3">Edit</button>
            </form>
        </div>
    </div>